# API keys — copy this file to .env and fill in. NEVER commit .env.
GEMINI_API_KEY=
OPENAI_API_KEY=

# vast.ai API key — enables cloud GPU training (rent a GPU per run, auto-terminated).
# Get one at https://cloud.vast.ai -> Keys. Typical training run costs ~$1-2.
VAST_API_KEY=

# Maximum imported reference anchors sent to one API generation request.
# The full corpus remains in the dataset; default is 14.
LDS_MAX_GENERATION_REFERENCES=14

# Browser upload ceiling for large local corpora/backups (MB). The import route
# processes images in small batches; 2048 matches the portable ZIP safety limit.
LDS_MAX_UPLOAD_MB=2048
