{
  "name": "prep-my-avatar-frontend",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.21.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "node --test",
    "test:theme": "node --test tests/theme-token-contract.test.mjs",
    "test:guided": "node --test src/hooks/useGuidedFlow.test.js",
    "build": "vite build",
    "preview": "vite preview",
    "test:navigation": "node --test src/components/dataset/workspaceNavigation.test.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.check.json",
    "e2e": "pnpm run build && playwright test",
    "gate": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "qrcode.react": "4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-easy-crop": "6.2.2",
    "react-router-dom": "6.30.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.5.3",
    "axe-core": "4.12.1",
    "eslint": "9.39.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vite": "6.4.3"
  }
}
